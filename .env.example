PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=Cluster0
DB_NAME=betx365
DB_DIALECT=mongodb

# Auth
JWT_SECRET=your-strong-random-secret-here

# HighAPI Game Aggregator
HIGHAPI_ENABLED=true
HIGHAPI_PROVIDER=marbel
HIGHAPI_BASE_URL=https://motherpanel.six444.com
HIGHAPI_LAUNCH_PATH=/api/v1/launch.php
HIGHAPI_GAMES_PATH=/api/v1/games.php
HIGHAPI_X_API_KEY=your-highapi-x-api-key
HIGHAPI_SECRET_KEY=your-highapi-secret-key
HIGHAPI_CURRENCY_CODE=BDT

# Public URLs (set to your Vercel deployment URL)
HIGHAPI_RETURN_URL=https://YOUR-APP.vercel.app/api/v1/player/game-return
HIGHAPI_CALLBACK_URL=https://YOUR-APP.vercel.app/api/v1/player/game-callback
GAME_CALLBACK_URL=https://YOUR-APP.vercel.app/api/v1/player/game-callback
